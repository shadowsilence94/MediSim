# Backend environment template (copy to .env on each machine)
# Choose ONE Firebase admin credential method:
# 1) Local path:
FIREBASE_SERVICE_ACCOUNT_PATH=./keys/firebase-service-account.json
# 2) Or JSON secret in hosted environments:
# FIREBASE_SERVICE_ACCOUNT_JSON={...}

# Bootstrap admin users (comma-separated)
ADMIN_EMAILS=

# Allow both local dev and deployed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional fallback API keys
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# Optional if model assets are in custom location
# MEDISIM_DATA_DIR=/app/data
